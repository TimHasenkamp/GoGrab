# --- Server ---
GOGRAB_LISTEN_ADDR=:8080
GOGRAB_PUBLIC_BASE_URL=https://gograb.example.com
GOGRAB_LOG_LEVEL=info        # debug | info | warn | error
GOGRAB_TRUSTED_PROXY=1       # set to 1 when behind Traefik+Authentik (trust X-Authentik-* headers)

# --- Database ---
# Replace CHANGEME before deploying. For dev with docker-compose, the password
# is pulled from POSTGRES_PASSWORD below — keep them in sync.
GOGRAB_DATABASE_URL=postgres://gograb:CHANGEME@postgres:5432/gograb?sslmode=disable

# --- Defaults ---
GOGRAB_DEFAULT_TTL_HOURS=72
GOGRAB_MAX_CIPHERTEXT_BYTES=65536

# --- Rate limiting (public submit endpoints) ---
GOGRAB_RATE_PER_MIN=20
GOGRAB_RATE_BURST=5

# --- Notify (webhook only in v1) ---
GOGRAB_NOTIFY_WEBHOOK_URL=
GOGRAB_NOTIFY_WEBHOOK_TIMEOUT_SECONDS=5

# --- WebAuthn (master-KEK unlock) ---
GOGRAB_RP_DISPLAY_NAME=GoGrab
GOGRAB_RP_ID=localhost                                   # prod: gograb.example.com
GOGRAB_RP_ORIGINS=http://localhost:5173,http://localhost:8080
# 32-byte base64url session secret. Leave empty in dev (random per process).
# In prod set a stable value so in-flight ceremonies survive restarts:
#   head -c 32 /dev/urandom | basenc --base64url | tr -d '='
GOGRAB_SESSION_SECRET=

# --- Postgres (docker-compose only) ---
POSTGRES_USER=gograb
# !!! Generate a real password before deploying: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=gograb
